{
  "name": "editor_desktop",
  "private": true,
  "version": "1.0.0",
  "description": "Electron-packaged Note Harbor Editor with scraping disabled",
  "type": "module",
  "main": "src/main.js",
  "scripts": {
    "build:web": "node ./scripts/build-web.mjs",
    "prepare:package": "node ./scripts/prepare-package.mjs",
    "build": "pnpm run build:web && pnpm run prepare:package && electron-builder install-app-deps && electron-builder",
    "build:win": "pnpm run build:web && pnpm run prepare:package && electron-builder install-app-deps && electron-builder --win nsis portable",
    "pack": "pnpm run build:web && pnpm run prepare:package && electron-builder install-app-deps && electron-builder --dir"
  },
  "dependencies": {
    "@img/sharp-darwin-arm64": "0.34.5",
    "@img/sharp-win32-x64": "0.34.5",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.8.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "sharp": "^0.34.5",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.noteharbor.editor",
    "productName": "Note Harbor Editor",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "src/**/*",
      ".build/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../data",
        "to": "bundled-data"
      }
    ],
    "asarUnpack": [
      "**/*.node",
      "**/*.dll",
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "dir"
      ],
      "category": "Utility"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
