{
  "name": "noteharbor",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "concurrently \"pnpm --filter editor_server dev\" \"pnpm --filter editor_web dev\"",
    "build:editor:desktop:win": "pnpm --filter editor_desktop build:win",
    "build:viewer:flutter:data": "python3 scripts/build_flutter_viewer_dataset.py",
    "layout": "tsps --layout layout.yml"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
